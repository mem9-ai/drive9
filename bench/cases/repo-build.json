{
  "name": "repo-build",
  "description": "Compare git clone and build timings on native disk versus a drive9 FUSE mount.",
  "runs": 3,
  "storages": ["native", "fuse"],
  "repos": [
    {
      "id": "drive9",
      "language": "go",
      "url": "https://github.com/mem9-ai/drive9.git",
      "ref": "main",
      "build_dir": ".",
      "prewarm": [
        "go mod download"
      ],
      "build": [
        "make build"
      ],
      "clean": [
        "bin",
        "dist",
        "*.test",
        "*.out"
      ]
    },
    {
      "id": "opencode",
      "language": "typescript",
      "url": "https://github.com/sst/opencode.git",
      "ref": "dev",
      "build_dir": ".",
      "prewarm": [
        "bun install --frozen-lockfile"
      ],
      "build": [
        "bun install --frozen-lockfile",
        "bun run --cwd packages/opencode build"
      ],
      "clean": [
        ".turbo",
        "packages/opencode/bin",
        "packages/opencode/dist",
        "packages/app/dist",
        "packages/app/.output"
      ]
    },
    {
      "id": "pi",
      "language": "typescript",
      "url": "https://github.com/earendil-works/pi.git",
      "ref": "main",
      "build_dir": ".",
      "prewarm": [
        "npm ci --ignore-scripts"
      ],
      "build": [
        "npm ci --ignore-scripts",
        "npm run build"
      ],
      "clean": [
        "node_modules",
        "packages/*/dist",
        "packages/*/build"
      ]
    },
    {
      "id": "bun",
      "language": "zig-rust-cpp",
      "url": "https://github.com/oven-sh/bun.git",
      "ref": "main",
      "build_dir": ".",
      "prewarm": [
        "bun install --frozen-lockfile"
      ],
      "build": [
        "bun install --frozen-lockfile",
        "bun run build"
      ],
      "clean": [
        "build",
        "node_modules",
        "target",
        ".zig-cache",
        "zig-out"
      ]
    },
    {
      "id": "kimi-cli",
      "language": "python",
      "url": "https://github.com/MoonshotAI/kimi-cli.git",
      "ref": "main",
      "build_dir": ".",
      "prewarm": [
        "uv sync --frozen --all-extras --all-packages"
      ],
      "build": [
        "uv sync --frozen --all-extras --all-packages",
        "make build"
      ],
      "clean": [
        "dist",
        "build",
        ".venv",
        "web/dist",
        "vis/dist"
      ]
    },
    {
      "id": "codex",
      "language": "rust",
      "url": "https://github.com/openai/codex.git",
      "ref": "main",
      "build_dir": "codex-rs",
      "prewarm": [
        "cargo fetch --locked"
      ],
      "build": [
        "cargo build --locked"
      ],
      "clean": [
        "codex-rs/target"
      ]
    }
  ]
}
