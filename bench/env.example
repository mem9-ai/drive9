# Copy to a local .env file or export these before running the bench harness.
# Keep real secrets out of git; this file is documentation only.

# Root for all mutable benchmark state. Use a large, fast local disk on EC2.
BENCH_HOME=/mnt/drive9-bench

# Number of measured repeats. The default case uses 3.
BENCH_RUNS=3

# Comma-separated subset when debugging. Full run uses native,fuse.
BENCH_STORAGES=native,fuse

# Optional comma-separated repo subset, for quick probes such as drive9 only.
# BENCH_REPOS=drive9

# Production drive9 credential used by the CLI and FUSE mount.
DRIVE9_API_KEY=replace-me

# Optional path to the drive9 CLI. Defaults to the first drive9 found on PATH.
BENCH_DRIVE9_CLI=drive9

# FUSE mount defaults. Extra flags are appended after these defaults.
BENCH_DRIVE9_REMOTE=/
BENCH_DRIVE9_MOUNT_FLAGS=--mode=fuse --durability=interactive --perf-counters
BENCH_DRIVE9_MOUNT_TIMEOUT_SECONDS=60
BENCH_DRIVE9_UMOUNT_TIMEOUT_SECONDS=300

# Optional per-phase command timeouts. Leave unset for no timeout. The global
# value is a fallback; phase-specific values let clone failures stop quickly
# while long build phases still have room.
BENCH_COMMAND_TIMEOUT_SECONDS=600
BENCH_CLONE_TIMEOUT_SECONDS=300
BENCH_BUILD_TIMEOUT_SECONDS=1200
BENCH_PREWARM_TIMEOUT_SECONDS=1800

# Optional Git/FUSE reliability knobs. Use these when Git lock/ref operations
# need explicit local fsync boundaries on FUSE.
# BENCH_GIT_FSYNC=1
# BENCH_GIT_CHECKOUT_MODE=read-tree
# BENCH_GIT_CHECKOUT_RETRIES=2
# BENCH_GIT_FSYNC_SETTLE_SECONDS=2

# Coding-agent local overlay suite:
# bench/bin/run-localdeps-output-build.py
#
# This suite creates one fresh drive9 context per repo and compares native disk
# against Drive9 FUSE while routing .git, dependency installs, caches, temp
# trees, and known generated outputs to the coding-agent local overlay.
BENCH_DRIVE9_ENV=prod
BENCH_DRIVE9_SERVER=https://api.drive9.ai
# BENCH_DRIVE9_CONFIG=$HOME/.drive9/config_prod_bak
# BENCH_DRIVE9_CLI=$PWD/bin/drive9
# BENCH_DRIVE9_CONTEXT_PREFIX=bplo
# BENCH_RUN_LABEL=prod-coding-agent-localgit
# BENCH_REPOS=drive9,kimi-cli,kimi-code

# Fresh clones are deleted after each sample, so build-output cleanup before
# build is disabled by default. Enable only when reusing checkouts manually.
# BENCH_CLEAN_BEFORE_BUILD=1

# Tool caches. Defaults are under BENCH_HOME/cache.
# BUN_INSTALL_CACHE_DIR=
# UV_CACHE_DIR=
# CARGO_HOME=
# GOMODCACHE=
# npm_config_cache=
