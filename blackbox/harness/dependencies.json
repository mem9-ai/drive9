{
  "community.pjdfstest": {
    "name": "pjdfstest",
    "source": "https://github.com/pjd/pjdfstest",
    "license": "BSD-2-Clause",
    "default_ref": "master"
  },
  "community.ltp.*": {
    "name": "Linux Test Project",
    "source": "https://github.com/linux-test-project/ltp",
    "license": "GPL-2.0-or-later",
    "default_ref": "20240129"
  },
  "community.fio": {
    "name": "fio",
    "source": "https://github.com/axboe/fio",
    "license": "GPL-2.0-only",
    "default_ref": "fio-3.42"
  },
  "community.mdtest": {
    "name": "IOR/mdtest",
    "source": "https://github.com/hpc/ior",
    "license": "GPL-2.0-only",
    "default_ref": "4.0.0",
    "patches": [
      "gcc15-option-callback-signature"
    ]
  },
  "community.fsx": {
    "name": "LTP fsx-linux",
    "source": "https://github.com/linux-test-project/ltp",
    "license": "GPL-2.0-or-later",
    "default_ref": "20240129",
    "fallback_source": "https://github.com/billziss-gh/secfs.test"
  },
  "community.vdbench": {
    "name": "vdbench",
    "source": "https://www.oracle.com/downloads/server-storage/vdbench-downloads.html",
    "license": "Oracle manual download",
    "note": "Manual dependency: blackbox does not auto-download vdbench. Run explicitly with VDBENCH_BIN or put vdbench on PATH."
  },
  "git.official.*": {
    "name": "Git upstream test suite",
    "source": "https://github.com/git/git",
    "license": "GPL-2.0-only",
    "default_ref": "v2.49.0"
  },
  "juicefs.*": {
    "name": "JuiceFS-inspired tests",
    "source": "https://github.com/juicedata/juicefs",
    "license": "Apache-2.0",
    "note": "The Drive9 blackbox modules are independent equivalent rewrites for generic filesystem behavior, not vendored JuiceFS test code."
  }
}
