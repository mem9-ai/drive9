          "t0001-init.sh",
          "t1300-config.sh",
          "t1400-update-ref.sh",
          "t1450-fsck.sh",
          "t1500-rev-parse.sh",
          "t2020-checkout-detach.sh",
          "t3700-add.sh",
          "t3903-stash.sh",
          "t4013-diff-various.sh",
